USE Aleksei_Tund3
CREATE TABLE customers(
customer_id int PRIMARY KEY identity (1,1),
first_name Varchar(20),
last_name Varchar (20),
phone Varchar (25),
email Varchar (30),
street Varchar (30),
city Varchar (30),
country_state Varchar (35),
zip_code Varchar (10)
)

